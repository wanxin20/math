# 搴旂敤閰嶇疆
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# 鏁版嵁搴撻厤缃?DB_HOST=dbconn.sealosgzg.site
DB_PORT=36594
DB_USERNAME=root
DB_PASSWORD=your_password
DB_DATABASE=teacher_research_platform

# JWT閰嶇疆
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# 鏂囦欢涓婁紶閰嶇疆
UPLOAD_MAX_SIZE=52428800
UPLOAD_DEST=./uploads

# Google Gemini AI閰嶇疆
GEMINI_API_KEY=your_gemini_api_key

# 鏃ュ織閰嶇疆
LOG_LEVEL=debug
LOG_MAX_FILES=30d

# CORS閰嶇疆
CORS_ORIGIN=http://localhost:5173

# Aliyun OSS (optional). New uploads go to a private OSS bucket; old files stay on local /uploads.
# Leave OSS_ENABLED unset/false to keep using local disk storage.
OSS_ENABLED=false
OSS_REGION=oss-cn-shenzhen
OSS_ACCESS_KEY_ID=your-oss-access-key-id
OSS_ACCESS_KEY_SECRET=your-oss-access-key-secret
OSS_BUCKET=your-bucket-name
# Use internal endpoint (true) only when the server (ECS) is in the same region as the bucket; set false for local dev.
OSS_INTERNAL=false
